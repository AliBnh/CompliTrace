# Postgres bootstrap
POSTGRES_USER=complitrace
POSTGRES_PASSWORD=
POSTGRES_DB=complitrace

# App connection
DATABASE_URL=postgresql://complitrace:@postgres:5432/complitrace

# AI providers
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

MODEL_PROVIDER=groq
MODEL_NAME=llama-3.1-8b-instant
MODEL_TEMPERATURE=0.1

FALLBACK_MODEL_PROVIDER=groq
FALLBACK_MODEL_NAME=qwen/qwen3-32b
FALLBACK_MODEL_TEMPERATURE=0.1

# Embeddings / retrieval
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=gdpr_chunks
CORPUS_VERSION=gdpr-2016-679-v1

# Prompt / provenance
PROMPT_TEMPLATE_VERSION=v1.0

MAX_LLM_CALLS_PER_AUDIT=80
MAX_AUDIT_RUNTIME_SECONDS=600

# Auth service
AUTH_SERVICE_URL=http://auth-service:8004
AUTH_JWT_SECRET=change-this-secret-before-production
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRY_HOURS=24